<div class="">
  <%= turbo_stream_from "tasks" %>
  <div class="flex justify-between">
    <h1 class="text-xl mb-2 font-semibold">Tasks</h1>
    <%= button_to "Refresh", "", { :onclick => "history.go(0)", class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 me-2 mb-2 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800"} %>
  </div>
  <div class="rounded-lg shadow">
    <table iclass="w-full">
      <thead class="">
        <tr>
          <th class="p-3 text-sm font-semibold tracking-wide text-left border border-slate-400">Project</td>
          <th class="p-3 text-sm font-semibold tracking-wide text-left border border-slate-400">Progress</td>
          <th class="p-3 text-sm font-semibold tracking-wide text-left border border-slate-400">Status</td>
          <th class="p-3 text-sm font-semibold tracking-wide text-left border border-slate-400">Elapsed</td>
          <th class="p-3 text-sm font-semibold tracking-wide text-left border border-slate-400">Remaining (est.)</td>
          <th class="p-3 text-sm font-semibold tracking-wide text-left border border-slate-400">Deadline</td>
          <th class="p-3 text-sm font-semibold tracking-wide text-left border border-slate-400">Application</td>
          <th class="p-3 text-sm font-semibold tracking-wide text-left border border-slate-400">Name</td>
          <th class="p-3 text-sm font-semibold tracking-wide text-left border border-slate-400">Computer</td>
          <th class="p-3 text-sm font-semibold tracking-wide text-left border border-slate-400">CPU</td>
        </tr>
      </thead>

      <tbody id="tasksTable" class="">
        <% @tasks.each do |task| %>
          <%= render partial: 'tasks/task', locals: { task: task } %>
        <% end %>
      <tbody>

      <tfooter>
        <tr></tr>
      </tfooter>
    </table>
  </div>
</div>